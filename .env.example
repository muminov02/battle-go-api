PORT=8080

# PostgreSQL — Go-owned DB for active battle state
PG_DSN=postgres://USER:PASSWORD@127.0.0.1:5432/battle_go?sslmode=disable

# MySQL — existing app DB (read questions/students, write final results)
MYSQL_DSN=USER:PASSWORD@tcp(127.0.0.1:3306)/v2_erp?parseTime=true

# Realtime transport: "ws" (default, native WebSocket) or "ably"
REALTIME_DRIVER=ws
# Full ws(s):// endpoint the frontend dials (must include the /ws path).
#   local:  ws://localhost:8080/student/v1/battle/ws
#   server: wss://v2-backend-erp.englifyschool.com/v2/battle/ws
WS_PUBLIC_URL=ws://localhost:8080/student/v1/battle/ws

# Ably (required only when REALTIME_DRIVER=ably)
ABLY_KEY=your-ably-key

# JWT RS256 public key (matches the PHP app's MAIN_JWT_PRIVATE_KEY). \n literals ok.
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
